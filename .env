#--------------------------------------------------------------------
# Example Environment Configuration file
#--------------------------------------------------------------------

# This file can be used as a starting point for your own
# custom .env files, and it has all of the possible settings
# you might want to configure.

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost/oms-codeigniter/'
app.forceGlobalSecureRequests = false
app.sessionDriver = 'CodeIgniter\Session\Handlers\FileHandler'
app.sessionCookieName = 'ci_session'
app.sessionExpiration = 7200
app.sessionSavePath = null
app.sessionMatchIP = false
app.sessionTimeToUpdate = 300
app.sessionRegenerateDestroy = false
app.CSRFProtection = true
app.CSRFTokenName = 'csrf_token'
app.CSRFHeaderName = 'X-CSRF-TOKEN'
app.CSRFCookieName = 'csrf_cookie_name'
app.CSRFExpire = 7200
app.CSRFRegenerate = true
app.CSRFExcludedURIs = []
app.CSRFSameSite = 'Lax'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = oms_codeigniter
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.disableForeignKeyConstraints = false

#--------------------------------------------------------------------
# CONTENT SECURITY POLICY
#--------------------------------------------------------------------

CSP.reportOnly = false
CSP.defaultSrc = 'self'
CSP.scriptSrc = 'self'
CSP.styleSrc = 'self'
CSP.imageSrc = 'self' data: https:
CSP.baseURI = null
CSP.childSrc = null
CSP.connectSrc = 'self'
CSP.fontSrc = 'self' data: https: fonts.gstatic.com
CSP.formAction = 'self'
CSP.frameAncestors = null
CSP.frameSrc = 'self'
CSP.mediaSrc = 'self'
CSP.objectSrc = 'none'
CSP.pluginTypes = null
CSP.reportURI = null
CSP.upgradeInsecureRequests = false

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key = 
encryption.driver = OpenSSL

#--------------------------------------------------------------------
# CONTENT SECURITY POLICY
#--------------------------------------------------------------------

CSP.reportOnly = false
CSP.defaultSrc = 'self'
CSP.scriptSrc = 'self' https://cdn.jsdelivr.net
CSP.styleSrc = 'self' https://cdn.jsdelivr.net 'unsafe-inline'
CSP.imageSrc = 'self' data: https:
CSP.fontSrc = 'self' https://cdn.jsdelivr.net

#--------------------------------------------------------------------
# HONEYPOT
#--------------------------------------------------------------------

honeypot.hidden = 'true'
honeypot.label = 'Fill in this field'
honeypot.name = 'bot'
honeypot.template = '<label>{label}</label><input type="text" name="{name}" value=""/>'
honeypot.container = '<div style="display:none">{template}</div>'
